    "@crxjs/vite-plugin": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/chrome": "^0.0.270",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
